# Canonical site URL used for OG, sitemap, RSS, JSON-LD.
# Leave unset in production — defaults to https://city-talks.gr.
NEXT_PUBLIC_SITE_URL=https://city-talks.gr

# ---------------------------------------------------------------------------
# Email (Resend)
# ---------------------------------------------------------------------------
# Sign up at https://resend.com, verify the city-talks.gr domain,
# then paste the API key below. If empty, the contact form will log to
# stdout and the newsletter form will append to content/newsletter-subscribers.json.
RESEND_API_KEY=

# Inbox that receives contact-form submissions.
CONTACT_TO_EMAIL=hello@city-talks.gr

# Verified sender. Must match a domain you own in Resend.
CONTACT_FROM_EMAIL="City Talks <no-reply@city-talks.gr>"

# ---------------------------------------------------------------------------
# Newsletter
# ---------------------------------------------------------------------------
# Optional. If set, /api/newsletter POSTs subscribers into this Resend Audience.
# Otherwise, subscribers are appended to content/newsletter-subscribers.json.
# Create an audience at https://resend.com/audiences and copy its id here.
NEWSLETTER_AUDIENCE_ID=
